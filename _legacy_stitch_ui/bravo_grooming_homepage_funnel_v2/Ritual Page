        .luxury-border {
            border: 1px solid rgba(189, 152, 101, 0.3);
        }

        .ingredient-card {
            background: rgba(253, 244, 233, 0.03);
            border: 1px solid rgba(189, 152, 101, 0.2);
            transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .ingredient-card:hover {
            border-color: var(--bronze);
            background: rgba(189, 152, 101, 0.08);
            transform: translateY(-4px);
        }

        .btn-primary {
            background-color: transparent;
            border: 1px solid var(--bronze);
            color: var(--bronze);
            transition: all 0.4s ease;
            position: relative;
            overflow: hidden;
        }

        .btn-primary:hover {
            background-color: var(--bronze);
            color: var(--obsidian);
            box-shadow: 0 0 30px rgba(189, 152, 101, 0.4);
        }

        .btn-filled {
            background-color: var(--bronze);
            color: var(--obsidian);
            border: 1px solid var(--bronze);
            transition: all 0.4s ease;
        }

        .btn-filled:hover {
            background-color: transparent;
            color: var(--bronze);
        }

        .reveal-text {
            opacity: 0;
            transform: translateY(30px);
        }

        .image-reveal {
            clip-path: inset(0 100% 0 0);
        }

        .parallax-slow {
            will-change: transform;
        }

        ::selection {
            background-color: var(--bronze);
            color: var(--obsidian);
        }

        .scrollbar-hide::-webkit-scrollbar {
            display: none;
        }

        .divider-bronze {
            height: 1px;
            background: linear-gradient(to right, transparent, var(--bronze), transparent);
        }

        @keyframes shimmer {
            0% {
                background-position: -1000px 0;
            }

            100% {
                background-position: 1000px 0;
            }
        }

        .shimmer-text {
            background: linear-gradient(90deg, var(--ivory) 0%, var(--bronze) 50%, var(--ivory) 100%);
            background-size: 1000px 100%;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            animation: shimmer 3s infinite linear;
        }
    </style>
